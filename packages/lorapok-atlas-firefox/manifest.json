{
  "manifest_version": 2,
  "name": "Lorapok Atlas — API Directory",
  "version": "1.0.0",
  "description": "Browse, search, and live-test 2100+ free open-source APIs directly in Firefox",
  "author": "Mohammad Maizied Hasan Majumder",
  "developer": {
    "name": "Mohammad Maizied Hasan Majumder",
    "url": "https://lorapok.github.io"
  },
  "homepage_url": "https://maijied.github.io/Lorapok-API_Atlas/",
  "browser_specific_settings": {
    "gecko": {
      "id": "lorapok-atlas@lorapok.github.io",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Lorapok Atlas — API Directory"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "clipboardWrite",
    "storage"
  ]
}
