{
  "name": "lorapok-atlas",
  "displayName": "Lorapok Atlas — API Directory",
  "description": "Browse, search, and insert code snippets from 2100+ free open-source APIs directly in VS Code",
  "version": "1.3.0",
  "publisher": "Lorapok",
  "icon": "media/icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Snippets"],
  "keywords": ["api", "rest", "snippets", "developer tools", "lorapok"],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "lorapok-atlas.open",
        "title": "Lorapok Atlas: Open API Directory",
        "icon": "media/icon-activity.svg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lorapok-atlas.open",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "lorapok-atlas.open",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "npx @vscode/vsce package --no-dependencies",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Maijied/Lorapok-API_Atlas.git",
    "directory": "packages/lorapok-atlas-vscode"
  },
  "homepage": "https://maijied.github.io/Lorapok-API_Atlas/",
  "license": "MIT"
}
